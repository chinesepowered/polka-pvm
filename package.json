    "deploy": "node scripts/deploy.js"
  },
  "dependencies": {
    "@parity/resolc": "^1.0.0",
    "ethers": "^6.13.0",
    "solc": "0.8.28"
  },
  "overrides": {
    "@parity/revive": {
      "solc": "0.8.28"
    }
  }
}
